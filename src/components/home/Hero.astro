---
import { getConfigurationCollection } from "../../lib/utils";

const { data: config } = await getConfigurationCollection();
---

<div class="flex flex-col items-center sm:flex-row gap-8">
  <img
    src={config.hero.image}
    alt={`${config.hero.title} Profile Image`}
    class="rounded-full max-w-40 w-40 h-40 z-0 grayscale"
  />
  <div class="flex flex-col gap-2">
    <h1 class="text-3xl sm:text-4xl font-display font-semibold opsz text-center sm:text-left">
      {config.hero.title}
    </h1>
    <div class="flex items-center gap-4 justify-center sm:justify-start">
      {
        config.personal.githubProfile && (
          <a href={config.personal.githubProfile} target="_blank" rel="noopener" aria-label="GitHub" class="inline-flex">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" class="zag-fill zag-transition">
              <title>GitHub</title>
              <path d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5c.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34c-.46-1.16-1.11-1.47-1.11-1.47c-.91-.62.07-.6.07-.6c1 .07 1.53 1.03 1.53 1.03c.87 1.52 2.34 1.07 2.91.83c.09-.65.35-1.09.63-1.34c-2.22-.25-4.55-1.11-4.55-4.92c0-1.11.38-2 1.03-2.71c-.1-.25-.45-1.29.1-2.64c0 0 .84-.27 2.75 1.02c.79-.22 1.65-.33 2.5-.33s1.71.11 2.5.33c1.91-1.29 2.75-1.02 2.75-1.02c.55 1.35.2 2.39.1 2.64c.65.71 1.03 1.6 1.03 2.71c0 3.82-2.34 4.66-4.57 4.91c.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2" />
            </svg>
          </a>
        )
      }
      {
        config.personal.email && (
          <a href={`mailto:${config.personal.email}`} aria-label="Email" class="inline-flex">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" class="zag-fill zag-transition">
              <title>Email</title>
              <path d="M3 3h18a1 1 0 0 1 1 1v16a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1zm17 4.24l-8 6.35L4 7.24V18h16V7.24zM4.45 5l7.55 6 7.55-6H4.45z" />
            </svg>
          </a>
        )
      }
      {
        config.personal.linkedinProfile && (
          <a href={config.personal.linkedinProfile} target="_blank" rel="noopener" aria-label="LinkedIn" class="inline-flex">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" class="zag-fill zag-transition">
              <title>LinkedIn</title>
              <path d="M19 0h-14c-2.76 0-5 2.24-5 5v14c0 2.76 2.24 5 5 5h14c2.76 0 5-2.24 5-5v-14c0-2.76-2.24-5-5-5zm-11.12 19h-3.08v-9h3.08v9zm-1.54-10.29c-.99 0-1.79-.8-1.79-1.79s.8-1.79 1.79-1.79 1.79.8 1.79 1.79-.8 1.79-1.79 1.79zm13.16 10.29h-3.08v-4.89c0-1.16-.02-2.64-1.61-2.64s-1.86 1.26-1.86 2.57v4.96h-3.08v-9h2.96v1.23h.04c.41-.78 1.4-1.6 2.88-1.6 3.08 0 3.65 2.03 3.65 4.66v4.71z" />
            </svg>
          </a>
        )
      }
      {
        config.personal.hackerNewsProfile && (
          <a href={config.personal.hackerNewsProfile} target="_blank" rel="noopener" aria-label="Hacker News" class="inline-flex">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256">
              <title>Hacker News</title>
              <rect class="zag-transition fill-neutral-900 dark:fill-neutral-100" width="256" height="256" rx="24" />
              <path class="zag-transition fill-neutral-100 dark:fill-neutral-900" d="M119.37 144.75L75.43 62.43h20.08l25.85 52.09c.4.93.86 1.89 1.39 2.88.53.99 1 2.02 1.39 3.08l.6 1.09.44.89c.66 1.33 1.26 2.62 1.79 3.88.53 1.26 1 2.42 1.39 3.48 1.06-2.25 2.22-4.67 3.48-7.26 1.26-2.58 2.55-5.27 3.88-8.05l26.25-52.09h18.69l-44.34 83.31v53.09h-16.9v-54.06z" />
            </svg>
          </a>
        )
      }
    </div>
    <span class="text-lg sm:text-xl font-mono font-medium text-center sm:text-left">
      Code & Notes
    </span>
  </div>
</div>
