---

<button
  class="border-none bg-none focus:outline-2 focus:outline-offset-2 focus:outline-zag-dark dark:focus:outline-zag-light zag-text zag-transition text-sm font-mono font-semibold px-1"
  type="button"
  id="langToggle"
  aria-label="Language Toggle"
>
  EN
</button>

<script is:inline>
  const handleLangClick = () => {
    const current = localStorage.getItem("lang") ?? "en";
    const next = current === "en" ? "zh" : "en";
    localStorage.setItem("lang", next);

    const prefix = next === "en" ? "" : "/zh";
    const path = window.location.pathname.replace(/^\/zh/, "") || "/";
    window.location.href = prefix + path;
  };

  document
    .getElementById("langToggle")
    ?.addEventListener("click", handleLangClick);
</script>
