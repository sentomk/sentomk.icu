---
import { getConfigurationCollection } from "../lib/utils";
import Anchor from "./common/Anchor.astro";

const { data: config } = await getConfigurationCollection();

const date = new Date();
const year = date.getFullYear();
---

<footer class="mt-24 zag-transition">
  <div class="p-4 max-w-2xl mx-auto">
    <!-- Bottom line: copyright -->
    <div class="zag-border-b zag-transition py-4 text-center text-[0.6rem] leading-loose tracking-widest zag-text-muted zag-transition font-display uppercase">
      &copy; {year} {config.personal.name} · Built with <a href="https://github.com/RATIU5/zaggonaut" class="underline zag-offset hover:opacity-70 transition-opacity" target="_blank" rel="noopener">Zaggonaut</a>
    </div>
  </div>
</footer>
